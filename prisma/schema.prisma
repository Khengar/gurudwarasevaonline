// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── LICENSES & TRUSTS ────────────────────────────────────────────

model License {
  id           String        @id @default(cuid())
  licenseKey   String        @unique
  issuedAt     DateTime      @default(now())
  expiresAt    DateTime?
  status       LicenseStatus @default(ACTIVE)
  notes        String?
  trusts       Trust[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum LicenseStatus {
  ACTIVE
  REVOKED
  EXPIRED
  SUSPENDED
}

model Trust {
  id             String     @id @default(cuid())
  name           String
  address        String?
  city           String?
  state          String?
  phone          String?
  email          String?
  logo           String?    // file path/url
  licenseId      String
  license        License    @relation(fields: [licenseId], references: [id])
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  users          User[]
  categoryHeads  CategoryHead[]
  receipts       Receipt[]
  payments       Payment[]
  rooms          Room[]
  roomBookings   RoomBooking[]
}

// ─── USERS ────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  trustId      String?   // null = SUPERADMIN (system-wide)
  trust        Trust?    @relation(fields: [trustId], references: [id])
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  permissions  Json      @default("[]")
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdReceipts   Receipt[]   @relation("ReceiptCreatedBy")
  createdPayments   Payment[]   @relation("PaymentCreatedBy")
  createdBookings   RoomBooking[] @relation("BookingCreatedBy")
}

enum UserRole {
  SUPERADMIN   // System-wide: manages trusts, licenses
  ADMIN        // Trust-level: manages all data for one trust
  USER         // Trust-level: data entry + view only
}

// ─── CATEGORY HIERARCHY ───────────────────────────────────────────

model CategoryHead {
  id           String       @id @default(cuid())
  trustId      String
  trust        Trust        @relation(fields: [trustId], references: [id])
  type         EntryType    // RECEIPT or PAYMENT
  name         String
  namePunjabi  String?
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  categories   Category[]

  @@unique([trustId, type, name])
}

model Category {
  id           String       @id @default(cuid())
  headId       String
  head         CategoryHead @relation(fields: [headId], references: [id])
  trustId      String
  name         String
  namePunjabi  String?
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  receipts     Receipt[]
  payments     Payment[]

  @@unique([headId, name])
}

enum EntryType {
  RECEIPT
  PAYMENT
}

// ─── RECEIPTS ─────────────────────────────────────────────────────

model Receipt {
  id            String      @id @default(cuid())
  trustId       String
  trust         Trust       @relation(fields: [trustId], references: [id])
  receiptNo     String
  fullName      String
  mobileNumber  String?
  address       String?
  amount        Decimal     @db.Decimal(12, 2)
  paymentType   PaymentType
  chequeNo      String?     // if paymentType = CHEQUE
  bankName      String?
  transactionId String?     // if UPI/ONLINE
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  notes         String?
  date          DateTime
  createdById   String
  createdBy     User        @relation("ReceiptCreatedBy", fields: [createdById], references: [id])
  isCollected   Boolean     @default(false)
  collectedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([trustId, receiptNo])
}

// ─── PAYMENTS ─────────────────────────────────────────────────────

model Payment {
  id            String      @id @default(cuid())
  trustId       String
  trust         Trust       @relation(fields: [trustId], references: [id])
  paymentNo     String
  payeeName     String
  mobileNumber  String?
  amount        Decimal     @db.Decimal(12, 2)
  paymentType   PaymentType
  chequeNo      String?
  bankName      String?
  transactionId String?
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  notes         String?
  date          DateTime
  createdById   String
  createdBy     User        @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([trustId, paymentNo])
}

enum PaymentType {
  CASH
  CHEQUE
  UPI
  ONLINE
  NEFT
  RTGS
}

// ─── ROOMS & BOOKINGS ─────────────────────────────────────────────

model Room {
  id            String       @id @default(cuid())
  trustId       String
  trust         Trust        @relation(fields: [trustId], references: [id])
  roomNumber    String
  name          String
  type          RoomType
  capacity      Int          @default(2)
  ratePerDay    Decimal      @db.Decimal(10, 2)
  description   String?
  amenities     Json?        // array of strings: ["AC", "Hot Water", "TV"]
  floor         String?
  status        RoomStatus   @default(AVAILABLE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  bookings      RoomBooking[]

  @@unique([trustId, roomNumber])
}

enum RoomType {
  SINGLE
  DOUBLE
  DORMITORY
  FAMILY
  SUITE
  VIP
}

enum RoomStatus {
  AVAILABLE
  UNDER_MAINTENANCE
  INACTIVE
}

model RoomBooking {
  id              String        @id @default(cuid())
  trustId         String
  trust           Trust         @relation(fields: [trustId], references: [id])
  bookingNo       String
  roomId          String
  room            Room          @relation(fields: [roomId], references: [id])
  guestName       String
  mobileNumber    String
  email           String?
  address         String?
  idProofType     String?       // Aadhaar, PAN, Passport, etc.
  idProofNo       String?
  checkIn         DateTime
  checkOut        DateTime
  adults          Int           @default(1)
  children        Int           @default(0)
  totalNights     Int
  ratePerNight    Decimal       @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  advancePaid     Decimal       @db.Decimal(12, 2) @default(0)
  balanceDue      Decimal       @db.Decimal(12, 2) @default(0)
  paymentStatus   BookingPaymentStatus @default(PENDING)
  paymentType     PaymentType?
  bookingStatus   BookingStatus @default(CONFIRMED)
  notes           String?
  createdById     String
  createdBy       User          @relation("BookingCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([trustId, bookingNo])
}

enum BookingStatus {
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum BookingPaymentStatus {
  PENDING
  PARTIAL
  PAID
}